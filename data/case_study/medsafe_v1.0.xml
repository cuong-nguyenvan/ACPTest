    <!-- R01 DOC read med-rec [assigned-patient] → Permit -->
    <Policy PolicyId="R01" Version="1.0"
            RuleCombiningAlgId="urn:oasis:names:tc:xacml:1.0:rule-combining-algorithm:first-applicable">
      <Target>
        <AnyOf><AllOf>
          <Match MatchId="urn:oasis:names:tc:xacml:1.0:function:string-equal">
            <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string">DOC</AttributeValue>
            <AttributeDesignator Category="urn:oasis:names:tc:xacml:1.0:subject-category:access-subject"
                                 AttributeId="urn:his:attr:role" DataType="http://www.w3.org/2001/XMLSchema#string" MustBePresent="true"/>
          </Match>
          <Match MatchId="urn:oasis:names:tc:xacml:1.0:function:string-equal">
            <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string">read</AttributeValue>
            <AttributeDesignator Category="urn:oasis:names:tc:xacml:3.0:attribute-category:action"
                                 AttributeId="urn:oasis:names:tc:xacml:1.0:action:action-id" DataType="http://www.w3.org/2001/XMLSchema#string" MustBePresent="true"/>
          </Match>
          <Match MatchId="urn:oasis:names:tc:xacml:1.0:function:string-equal">
            <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string">med-rec</AttributeValue>
            <AttributeDesignator Category="urn:oasis:names:tc:xacml:3.0:attribute-category:resource"
                                 AttributeId="urn:his:attr:resource-type" DataType="http://www.w3.org/2001/XMLSchema#string" MustBePresent="true"/>
          </Match>
        </AllOf></AnyOf>
      </Target>
      <Rule RuleId="r01" Effect="Permit">
        <Condition>
          <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:string-is-in">
            <AttributeDesignator Category="urn:oasis:names:tc:xacml:3.0:attribute-category:resource"
                                 AttributeId="urn:his:attr:patient-id" DataType="http://www.w3.org/2001/XMLSchema#string" MustBePresent="true"/>
            <AttributeDesignator Category="urn:oasis:names:tc:xacml:1.0:subject-category:access-subject"
                                 AttributeId="urn:his:attr:assigned-patients" DataType="http://www.w3.org/2001/XMLSchema#string" MustBePresent="true"/>
          </Apply>
        </Condition>
      </Rule>
    </Policy>

    <!-- R02–R13: structural stubs (full conditions in production XML) -->
